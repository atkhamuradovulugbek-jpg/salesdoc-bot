# =============================================
# .env.example — bu faylni nusxalab .env qiling
# va qiymatlarni o'zingiznikiga o'zgartiring.
# .env faylini HECH KIMGA YUBORMANG!
# =============================================

# --- Telegram ---
# BotFather'dan olingan token (uzun raqam-harf qatori)
TELEGRAM_BOT_TOKEN=

# Botdan foydalana oladigan Telegram ID'lar (vergul bilan)
# @userinfobot ga /start yozing — u sizga ID'ingizni beradi
ALLOWED_TELEGRAM_IDS=123456789

# Kunlik xulosa va ogohlantirishlar shu ID'larga yuboriladi
ADMIN_TELEGRAM_IDS=123456789

# --- Sales Doctor ---
# Masalan: https://yourcompany.salesdoc.uz/api/v2
SALESDOC_BASE_URL=https://DOMAIN/api/v2
SALESDOC_LOGIN=
SALESDOC_PASSWORD=

# --- Chegaralar (ixtiyoriy, standart qiymatlar yaxshi) ---
# O'lik do'kon: necha kun buyurtma bo'lmasa "o'lik" hisoblanadi
DEAD_OUTLET_DAYS=14
# Oxirgi necha kunda faol bo'lgan do'konlarni tekshiramiz
DEAD_OUTLET_LOOKBACK_DAYS=90
# Agent qarzi shu summadan oshsa ogohlantirish (0 = o'chirilgan)
DEBT_ALERT_THRESHOLD=0
# Savdo kechaga nisbatan shu % tushsa ogohlantirish
SALES_DROP_ALERT_PERCENT=20
